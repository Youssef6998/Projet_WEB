{
    "require": {
        "twig/twig": "^3.23"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "App\\Models\\": "models/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php vendor/bin/phpunit --testdox | sed 's/ ✔ /   /g' | sed 's/ ✘ /   /g'"
    }
}

[req]
default_bits = 2048
prompt = no
default_md = sha256
req_extensions = req_ext
distinguished_name = dn

[dn]
C = FR
ST = Loire-Atlantique
L = Saint-Nazaire
O = Projet Web
CN = projet-web.local

[req_ext]
subjectAltName = @alt_names

[alt_names]
DNS.1 = projet-web.local
DNS.2 = www.projet-web.local
